XMTPD_APP_CHAIN_WSS_URL= # Get from Alchemy
XMTPD_APP_CHAIN_RPC_URL= # Get from Alchemy
XMTPD_SETTLEMENT_CHAIN_WSS_URL= # Get from Alchemy
XMTPD_SETTLEMENT_CHAIN_RPC_URL= # Get from Alchemy
XMTPD_CONTRACTS_ENVIRONMENT=testnet-staging
XMTPD_PAYER_PRIVATE_KEY= # Generate via xmtpd-cli keys generate
XMTPD_REDIS_URL=redis://redis:6777
XMTPD_API_PORT=5872

# Gateway auth mode:
#   allowall   - no authentication
#   jwt_es256  - JWT auth using ES256 (ECDSA P-256)
GATEWAY_AUTH_MODE=allowall

# JWT settings (required only if GATEWAY_AUTH_MODE=jwt_es256)
JWT_EXPECTED_ISSUER=example.org
# PEM public key, newlines escaped as \n
JWT_PUBLIC_KEY=
